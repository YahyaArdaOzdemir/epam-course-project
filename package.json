{
  "name": "innovatepam-portal",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend",
    "e2e"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:coverage",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --selectProjects backend-unit frontend-unit",
    "test:integration": "jest --selectProjects backend-integration frontend-integration",
    "test:coverage": "jest --coverage --selectProjects backend-unit frontend-unit",
    "test:e2e": "playwright test",
    "lint:openapi": "swagger-cli validate specs/002-innovateepam-portal/contracts/openapi.yaml",
    "lint": "npm --workspace backend run lint && npm --workspace frontend run lint",
    "build": "npm --workspace backend run build && npm --workspace frontend run build"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@playwright/test": "^1.53.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}